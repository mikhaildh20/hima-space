# HIMA Space - Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://hima_user:hima_password@localhost:5432/hima_space?schema=public"

# JWT
JWT_SECRET="hima-space-super-secret-jwt-key-min-32-chars-replace-in-production"

# App
NODE_ENV="production"
PORT=4000

# API Configuration
API_BASE_URL="http://localhost:4000"

# CORS
CORS_ORIGIN="http://localhost:3300,http://127.0.0.1:3300"

# Security
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL="info"
